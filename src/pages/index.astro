---
// src/pages/index.astro
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import ToolGrid from '@/components/home/ToolGrid.astro';
import FeaturedStandards from '@/components/home/FeaturedStandards.astro';
import HowItWorks from '@/components/home/HowItWorks.astro';
import StructuredData from '@/components/seo/StructuredData.astro';
import { buildWebSiteSchema, buildOrganizationSchema } from '@/lib/seo/schema';

const websiteSchema = buildWebSiteSchema();
const orgSchema = buildOrganizationSchema();
const schemas = [websiteSchema, orgSchema];
---

<PageLayout
  title="StrengthAtlas | Strength Standards & Relative Strength Platform"
  description="Calculate your Strength Index composite rating. Browse strict strength standards for Bench Press, Squats, Deadlifts, Overhead Press, and Pull-Ups."
  canonicalPath="/"
>
  <StructuredData slot="head" schema={schemas} />

  {/* Flagship Hero section with integrated calculator */}
  <HeroSection />

  {/* Tool Navigation Grid */}
  <ToolGrid />

  {/* Featured 80kg Male intermediate standards */}
  <FeaturedStandards />

  {/* Calculation methodology steps */}
  <HowItWorks />
</PageLayout>
