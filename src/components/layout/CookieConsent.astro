---
// src/components/layout/CookieConsent.astro
---

<div
  id="cookie-consent-banner"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] sm:w-full max-w-2xl glass rounded-2xl shadow-2xl p-5 md:p-6 z-50 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 md:gap-8 opacity-0 pointer-events-none translate-y-8 transition-all duration-500 ease-spring"
  aria-hidden="true"
>
  <div class="space-y-2 flex-1">
    <h4 class="text-sm font-bold text-foreground flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4 text-primary"
      >
        <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5" />
        <path d="M8.5 8.5v.01" />
        <path d="M16 15.5v.01" />
        <path d="M12 12v.01" />
        <path d="M11 17v.01" />
        <path d="M7 14v.01" />
      </svg>
      Cookie Preferences
    </h4>
    <p class="text-xs text-muted-foreground leading-relaxed">
      We use cookies to analyze traffic, customize your experience, and serve personalized advertisements via Google AdSense. Read our 
      <a href="/privacy" class="text-primary hover:underline font-medium">Privacy Policy</a> to learn more.
    </p>
  </div>
  <div class="flex items-center gap-3 w-full md:w-auto justify-end">
    <button
      id="decline-cookies"
      class="px-4 py-2 text-xs font-semibold text-muted-foreground hover:text-foreground transition-colors border border-border rounded-lg hover:bg-muted/30 cursor-pointer"
    >
      Decline
    </button>
    <button
      id="accept-cookies"
      class="px-5 py-2 text-xs font-semibold bg-primary text-primary-foreground hover:bg-primary/90 transition-all rounded-lg glow-primary shadow-sm hover:scale-[1.02] active:scale-[0.98] cursor-pointer whitespace-nowrap"
    >
      Accept All
    </button>
  </div>
</div>

<style>
  #cookie-consent-banner.show-banner {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-consent-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const declineBtn = document.getElementById('decline-cookies');

    if (!banner || !acceptBtn || !declineBtn) return;

    // Check if consent has already been given or declined
    const consent = localStorage.getItem('cookie-consent');

    if (!consent) {
      // Small delay to ensure smooth entry animation
      setTimeout(() => {
        banner.classList.add('show-banner');
        banner.removeAttribute('aria-hidden');
      }, 800);
    }

    const hideBanner = () => {
      banner.classList.remove('show-banner');
      banner.setAttribute('aria-hidden', 'true');
    };

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'accepted');
      hideBanner();
      // Dispatch custom event if other analytics/scripts need to listen to it
      window.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: 'accepted' }));
    });

    declineBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'declined');
      hideBanner();
      window.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: 'declined' }));
    });
  });
</script>
