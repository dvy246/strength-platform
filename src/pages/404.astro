---
// src/pages/404.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/layout/Container.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
---

<BaseLayout
  title="Page Not Found (404) | StrengthChecker"
  description="The page you are looking for does not exist or has been relocated."
  noindex={true}
>
  <Header />

  <main class="flex-grow flex items-center justify-center py-24 relative overflow-hidden hero-gradient min-h-[70vh]">
    <div class="absolute inset-0 hero-grid pointer-events-none" />
    
    <Container class="relative z-10 text-center space-y-6 max-w-xl">
      <div class="space-y-2">
        <span class="text-xs font-semibold uppercase tracking-widest text-primary font-mono select-none">Error 404</span>
        <h1 class="text-7xl md:text-8xl font-black tracking-tighter text-gradient leading-none">404</h1>
        <h2 class="text-2xl font-bold text-foreground mt-4">Page Not Found</h2>
        <p class="text-sm text-muted-foreground leading-relaxed mt-2 max-w-sm mx-auto">
          The link you followed may be broken, or the page has been moved. Use the options below to find your way back.
        </p>
      </div>

      <div class="pt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-primary px-6 py-3 text-sm font-bold text-primary-foreground hover:bg-primary/95 shadow-sm active:scale-[0.99] transition-all select-none"
        >
          Return to Home
        </a>
        <a
          href="/calculators"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl border border-border bg-card px-6 py-3 text-sm font-bold hover:bg-muted text-foreground transition-all select-none"
        >
          View Calculators
        </a>
      </div>

      <div class="border-t border-border/80 pt-6 mt-12 text-left">
        <h3 class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-3 font-mono">Popular Tools</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2 text-xs">
          <li><a href="/calculators/strength-index" class="text-muted-foreground hover:text-primary transition-colors hover:underline">Strength Index</a></li>
          <li><a href="/calculators/one-rep-max-calculator" class="text-muted-foreground hover:text-primary transition-colors hover:underline">One Rep Max</a></li>
          <li><a href="/calculators/ideal-bodyweight" class="text-muted-foreground hover:text-primary transition-colors hover:underline">Ideal Bodyweight</a></li>
          <li><a href="/calculators/relative-strength" class="text-muted-foreground hover:text-primary transition-colors hover:underline">Relative Strength</a></li>
        </ul>
      </div>
    </Container>
  </main>

  <Footer />
</BaseLayout>
