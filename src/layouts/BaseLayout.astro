---
// src/layouts/BaseLayout.astro
import '@/styles/global.css';
import Head from '@/components/seo/Head.astro';
import CookieConsent from '@/components/layout/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImagePath?: string;
  noindex?: boolean;
}

const { title, description, canonicalPath, ogImagePath, noindex } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-872F2MYES9" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-872F2MYES9');
    </script>
    <Head
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImagePath={ogImagePath}
      noindex={noindex}
    />
    <script is:inline>
      // Sync dark/light theme before rendering content to prevent flashing
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('sa-theme')) {
          return localStorage.getItem('sa-theme');
        }
        return 'dark'; // Dark default as per design specification
      };
      
      const theme = getTheme();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.add('dark');
        document.documentElement.classList.remove('light');
      }
    </script>
    <slot name="head" />
  </head>
  <body class="bg-background text-foreground antialiased selection:bg-primary/20 selection:text-primary">
    <a href="#main-content" class="skip-to-content">
      Skip to main content
    </a>
    <slot />
    <CookieConsent />
  </body>
</html>
