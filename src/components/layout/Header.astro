---
// src/components/layout/Header.astro
import Container from './Container.astro';
---

<header class="sticky top-0 z-50 w-full border-b border-border glass bg-background/80 backdrop-blur-xl">
  <Container>
    <div class="flex h-16 items-center justify-between">
      {/* Brand logo/wordmark */}
      <a href="/" class="flex items-center space-x-2.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:rounded-md">
        <img src="/favicon.svg" alt="StrengthAtlas Logo" class="h-6 w-6" />
        <span class="text-xl font-bold tracking-tight text-foreground hover:text-primary transition-colors">
          Strength<span class="text-primary">Atlas</span>
        </span>
      </a>

      {/* Desktop Navigation */}
      <nav class="hidden md:flex items-center space-x-8 text-sm font-medium text-muted-foreground">
        <a href="/strength-standards" class="hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:rounded">
          Standards
        </a>
        <a href="/calculators" class="hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:rounded">
          Calculators
        </a>
        <a href="/calculators/ideal-bodyweight" class="hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:rounded">
          Ideal Weight
        </a>
        <a href="/calculators/relative-strength" class="hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:rounded">
          Relative Strength
        </a>
        <a href="/methodology" class="hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring focus-visible:rounded">
          Methodology
        </a>
      </nav>

      {/* Desktop Controls */}
      <div class="hidden md:flex items-center space-x-4">
        {/* Unit Toggle (kg/lb) */}
        <div class="inline-flex rounded-lg border border-border bg-muted p-0.5" role="group" aria-label="Weight Unit">
          <button
            type="button"
            id="unit-toggle-kg"
            class="px-3 py-1 text-xs font-semibold rounded-md transition-all focus-visible:outline-none select-none"
          >
            KG
          </button>
          <button
            type="button"
            id="unit-toggle-lb"
            class="px-3 py-1 text-xs font-semibold rounded-md transition-all focus-visible:outline-none select-none"
          >
            LB
          </button>
        </div>

        {/* Theme Toggle Button */}
        <button
          id="theme-toggle"
          type="button"
          class="rounded-lg p-2 text-muted-foreground hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
          aria-label="Toggle Theme"
        >
          {/* Sun icon */}
          <svg id="theme-toggle-light-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          {/* Moon icon */}
          <svg id="theme-toggle-dark-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </div>

      {/* Mobile Actions */}
      <div class="flex items-center space-x-2 md:hidden">
        {/* Theme Toggle */}
        <button
          id="theme-toggle-mobile"
          type="button"
          class="rounded-lg p-2 text-muted-foreground hover:bg-muted focus-visible:outline-none"
          aria-label="Toggle Theme"
        >
          <svg id="theme-toggle-light-icon-mobile" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <svg id="theme-toggle-dark-icon-mobile" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        {/* Mobile Menu Toggler */}
        <button
          id="mobile-menu-toggle"
          type="button"
          class="rounded-lg p-2 text-muted-foreground hover:bg-muted focus-visible:outline-none"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle Navigation Menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="mobile-menu-hamburger" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="mobile-menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </Container>

  {/* Mobile Menu Drawer */}
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-background/95 backdrop-blur-xl transition-all duration-300"
  >
    <div class="space-y-1 px-4 py-4">
      <a href="/strength-standards" class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground">
        Standards
      </a>
      <a href="/calculators" class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground">
        Calculators
      </a>
      <a href="/calculators/ideal-bodyweight" class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground">
        Ideal Weight
      </a>
      <a href="/calculators/relative-strength" class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground">
        Relative Strength
      </a>
      <a href="/methodology" class="block rounded-md px-3 py-2 text-base font-medium text-muted-foreground hover:bg-muted hover:text-foreground">
        Methodology
      </a>
      <div class="border-t border-border my-4 pt-4 flex items-center justify-between px-3">
        <span class="text-sm font-medium text-muted-foreground">Weight Unit</span>
        <div class="inline-flex rounded-lg border border-border bg-muted p-0.5">
          <button
            type="button"
            id="unit-toggle-kg-mobile"
            class="px-4 py-1 text-xs font-semibold rounded-md transition-all select-none"
          >
            KG
          </button>
          <button
            type="button"
            id="unit-toggle-lb-mobile"
            class="px-4 py-1 text-xs font-semibold rounded-md transition-all select-none"
          >
            LB
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Client-side theme toggle
  const themeToggleBtn = document.getElementById('theme-toggle');
  const themeToggleBtnMobile = document.getElementById('theme-toggle-mobile');
  const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIconMobile = document.getElementById('theme-toggle-light-icon-mobile');
  const themeToggleDarkIconMobile = document.getElementById('theme-toggle-dark-icon-mobile');

  const updateThemeUI = (isDark: boolean) => {
    if (isDark) {
      themeToggleLightIcon?.classList.remove('hidden');
      themeToggleDarkIcon?.classList.add('hidden');
      themeToggleLightIconMobile?.classList.remove('hidden');
      themeToggleDarkIconMobile?.classList.add('hidden');
    } else {
      themeToggleLightIcon?.classList.add('hidden');
      themeToggleDarkIcon?.classList.remove('hidden');
      themeToggleLightIconMobile?.classList.add('hidden');
      themeToggleDarkIconMobile?.classList.remove('hidden');
    }
  };

  const isDarkInitial = document.documentElement.classList.contains('dark');
  updateThemeUI(isDarkInitial);

  const toggleTheme = () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('sa-theme', 'light');
      updateThemeUI(false);
    } else {
      document.documentElement.classList.remove('light');
      document.documentElement.classList.add('dark');
      localStorage.setItem('sa-theme', 'dark');
      updateThemeUI(true);
    }
  };

  themeToggleBtn?.addEventListener('click', toggleTheme);
  themeToggleBtnMobile?.addEventListener('click', toggleTheme);

  // Client-side mobile menu
  const mobileMenuToggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('mobile-menu-hamburger');
  const closeIcon = document.getElementById('mobile-menu-close');

  mobileMenuToggleBtn?.addEventListener('click', () => {
    const isExpanded = mobileMenuToggleBtn.getAttribute('aria-expanded') === 'true';
    mobileMenuToggleBtn.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
    mobileMenu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Client-side units toggle synced with localStorage & CustomEvent
  const kgBtn = document.getElementById('unit-toggle-kg');
  const lbBtn = document.getElementById('unit-toggle-lb');
  const kgBtnMobile = document.getElementById('unit-toggle-kg-mobile');
  const lbBtnMobile = document.getElementById('unit-toggle-lb-mobile');

  const updateUnitUI = (unit: 'kg' | 'lb') => {
    const activeClasses = ['bg-background', 'text-foreground', 'shadow-sm'];
    const inactiveClasses = ['text-muted-foreground', 'hover:text-foreground'];

    if (unit === 'kg') {
      [kgBtn, kgBtnMobile].forEach(btn => {
        btn?.classList.add(...activeClasses);
        btn?.classList.remove(...inactiveClasses);
      });
      [lbBtn, lbBtnMobile].forEach(btn => {
        btn?.classList.remove(...activeClasses);
        btn?.classList.add(...inactiveClasses);
      });
    } else {
      [lbBtn, lbBtnMobile].forEach(btn => {
        btn?.classList.add(...activeClasses);
        btn?.classList.remove(...inactiveClasses);
      });
      [kgBtn, kgBtnMobile].forEach(btn => {
        btn?.classList.remove(...activeClasses);
        btn?.classList.add(...inactiveClasses);
      });
    }
  };

  const getStoredUnit = (): 'kg' | 'lb' => {
    return (localStorage.getItem('sa-unit') as 'kg' | 'lb') || 'kg';
  };

  const setStoredUnit = (unit: 'kg' | 'lb') => {
    localStorage.setItem('sa-unit', unit);
    updateUnitUI(unit);
    window.dispatchEvent(new CustomEvent('sa:unit-change', { detail: unit }));
  };

  // Initialize
  const currentUnit = getStoredUnit();
  updateUnitUI(currentUnit);

  kgBtn?.addEventListener('click', () => setStoredUnit('kg'));
  kgBtnMobile?.addEventListener('click', () => setStoredUnit('kg'));
  lbBtn?.addEventListener('click', () => setStoredUnit('lb'));
  lbBtnMobile?.addEventListener('click', () => setStoredUnit('lb'));

  // Listen to unit changes from other React/Astro components
  window.addEventListener('sa:unit-change', ((e: CustomEvent<'kg' | 'lb'>) => {
    updateUnitUI(e.detail);
  }) as EventListener);
</script>
