---
// src/components/seo/SEOFAQSection.astro
import type { FAQItem } from '@/data/faqs';
import StructuredData from './StructuredData.astro';

export interface Props {
  title?: string;
  items: FAQItem[];
  class?: string;
}

const { title = "Frequently Asked Questions", items, class: className = "" } = Astro.props;

// Generate JSON-LD Schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': items.map((item) => ({
    '@type': 'Question',
    'name': item.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': item.answer
    }
  }))
};
---

<StructuredData schema={faqSchema} />

<div class={`p-6 md:p-8 border border-border rounded-2xl bg-card/60 shadow-md space-y-6 ${className}`}>
  <div>
    <h2 class="text-xl md:text-2xl font-bold text-foreground">
      {title}
    </h2>
    <p class="text-xs text-muted-foreground mt-1">
      Have questions? Find quick answers regarding our calculations and models below.
    </p>
  </div>

  <div class="space-y-4 divide-y divide-border/60">
    {items.map((item, index) => (
      <details 
        class="group pt-4 first:pt-0 [&_summary::-webkit-details-marker]:hidden focus-visible:outline-none"
      >
        <summary class="flex cursor-pointer items-center justify-between gap-1.5 text-foreground list-none focus-visible:outline-none">
          <h3 class="text-sm font-semibold text-foreground group-open:text-primary transition-colors pr-4">
            {item.question}
          </h3>
          <span class="shrink-0 rounded-lg bg-muted/50 p-1 text-muted-foreground group-open:-rotate-180 group-open:text-primary transition-all duration-300">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <p class="mt-3 text-xs leading-relaxed text-muted-foreground/90 font-medium pl-1 select-text">
          {item.answer}
        </p>
      </details>
    ))}
  </div>
</div>
