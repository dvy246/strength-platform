---
// src/components/home/HeroSection.astro
import Container from '../layout/Container.astro';
import { StrengthIndex } from '../calculators/StrengthIndex';
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden py-20 border-b border-border hero-gradient">
  {/* Grid overlay for premium Vercel look */}
  <div class="absolute inset-0 hero-grid pointer-events-none" />

  <Container class="relative z-10">
    <div class="text-center max-w-4xl mx-auto space-y-6 mb-12">
      {/* Decorative tag */}
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold bg-primary/10 text-primary border border-primary/20 tracking-wider uppercase select-none">
        The Strength Intelligence Platform
      </span>
      
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
        How Strong Are You? <br />
        <span class="text-gradient font-black">Discover Your Score.</span>
      </h1>
      
      <p class="max-w-2xl mx-auto text-lg md:text-xl text-muted-foreground leading-relaxed">
        StrengthChecker is the definitive platform for strength standards. Calculate your <strong>Strength Index</strong> composite rating based on real competition data.
      </p>
    </div>

    {/* Integrated flagship calculator directly in hero */}
    <div class="w-full max-w-5xl mx-auto">
      <StrengthIndex client:load />
    </div>
  </Container>
</section>
