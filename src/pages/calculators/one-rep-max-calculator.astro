---
// src/pages/calculators/one-rep-max-calculator.astro
import CalculatorLayout from '@/layouts/CalculatorLayout.astro';
import { OneRepMax } from '@/components/calculators/OneRepMax';
import { oneRepMaxFAQs } from '@/data/faqs';
import SEOFAQSection from '@/components/seo/SEOFAQSection.astro';
---

<CalculatorLayout
  title="1 Rep Max Calculator | Calculate 1RM Lifts & Calc | StrengthChecker"
  description="Estimate your strict 1 rep max (1RM) using our precision powerlifting equations. Outputs training zones and a detailed 1 rep max calc table."
  calculatorName="1 Rep Max Calculator"
  canonicalPath="/calculators/one-rep-max-calculator"
>
  {/* The Interactive Calculator Island */}
  <OneRepMax slot="calculator" client:load />

  {/* Sidebar Content */}
  <div slot="sidebar" class="p-6 border border-border bg-card rounded-xl shadow-sm space-y-6">
    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Why 1 Rep Max Matters</h3>
    <p class="text-xs text-muted-foreground leading-relaxed">
      A <strong class="text-foreground">1 rep max</strong> is the maximum weight you can lift for a single repetition of an exercise with proper technique.
    </p>
    <p class="text-xs text-muted-foreground leading-relaxed">
      Most structured strength and <strong class="text-foreground">powerlifting</strong> programs (like 5/3/1, Starting Strength, or Daily Undulating Periodization) calculate your daily training loads as percentages of your 1RM. Knowing this number is essential for structured progression.
    </p>
    <div class="border-t border-border pt-4">
      <a href="/strength-standards" class="text-xs font-semibold text-primary hover:underline">
        Check exercise standards →
      </a>
    </div>
  </div>

  {/* Bottom Editorial Content */}
  <div class="space-y-8 max-w-3xl">
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-foreground">How is Your 1 Rep Max Calculated?</h2>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Calculating a 1RM mathematically is safer and less taxing on your central nervous system than attempting a true max failure lift. Our <strong class="text-foreground">1 rep max calculator</strong> uses six scientific formulas developed by sports scientists to estimate your maximum output based on sub-maximal efforts.
      </p>
    </section>

    <section class="space-y-4">
      <h3 class="text-xl font-bold text-foreground">Overview of the 1 Rep Max Calc Formulas</h3>
      <div class="space-y-3">
        <p class="text-muted-foreground text-sm leading-relaxed">
          <strong>1. Epley Formula:</strong> Created by Boyd Epley in 1985. It is the gold standard for basic compound lifts and is highly accurate when testing repetitions under 10.
        </p>
        <p class="text-muted-foreground text-sm leading-relaxed">
          <strong>2. Brzycki Formula:</strong> Developed by Matt Brzycki. It performs exceptionally well when working at lower rep ranges (2–6 reps) and tends to predict slightly higher 1RMs than Epley as reps increase.
        </p>
        <p class="text-muted-foreground text-sm leading-relaxed">
          <strong>3. Lombardi Formula:</strong> An exponential formula created by V.P. Lombardi. It is less sensitive to high repetitions and works well for high-rep sets.
        </p>
      </div>
    </section>

    <div class="border-t border-border/80 pt-6">
      <SEOFAQSection items={oneRepMaxFAQs} title="1 Rep Max FAQs" />
    </div>
  </div>
</CalculatorLayout>
