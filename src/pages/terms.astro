---
// src/pages/terms.astro
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';

const breadcrumbs = [{ name: 'Terms of Service', path: '/terms' }];
---

<PageLayout
  title="Terms & Conditions | StrengthChecker"
  description="Review the Terms & Conditions of using the StrengthChecker platform, including general disclaimers, intellectual property, and guidelines."
  canonicalPath="/terms"
>
  <Section class="pt-6 md:pt-10">
    <Container>
      <Breadcrumbs items={breadcrumbs} />

      <div class="mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl">
          Terms & <span class="text-gradient">Conditions</span>
        </h1>
        <p class="mt-3 text-lg text-muted-foreground max-w-2xl">
          Please read these terms carefully before using our platform.
        </p>
      </div>

      <div class="prose prose-invert max-w-3xl leading-relaxed text-muted-foreground text-sm space-y-6">
        <p>
          Welcome to StrengthChecker! These terms and conditions outline the rules and regulations for the use of StrengthChecker's Website, located at <a href="https://strengthchecker.com" class="text-primary hover:underline font-semibold">strengthchecker.com</a>.
        </p>
        <p>
          By accessing this website, we assume you accept these terms and conditions. Do not continue to use StrengthChecker if you do not agree to take all of the terms and conditions stated on this page.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Fitness and Health Disclaimer</h2>
        <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-xl text-xs text-red-200/90 leading-relaxed my-4">
          <strong>WARNING:</strong> The content, calculators, and tools provided on StrengthChecker are for informational and educational purposes only. They do not constitute professional medical advice, diagnosis, or physical therapy/training instructions. Compound lifting (Squats, Deadlifts, Bench Press) involves inherent injury risk. Consult a qualified physician or certified personal trainer before attempting new exercises or heavy maximal efforts.
        </div>

        <h2 class="text-xl font-bold text-foreground mt-8">Intellectual Property Rights</h2>
        <p>
          Unless otherwise stated, StrengthChecker and/or its licensors own the intellectual property rights for all material on StrengthChecker. All intellectual property rights are reserved. You may access this from StrengthChecker for your own personal use subjected to restrictions set in these terms and conditions.
        </p>
        <p>You must not:</p>
        <ul class="list-disc list-inside space-y-1.5 pl-4">
          <li>Republish material or mathematical curve coefficients from StrengthChecker</li>
          <li>Sell, rent or sub-license material from StrengthChecker</li>
          <li>Reproduce, duplicate or copy material from StrengthChecker</li>
          <li>Redistribute content from StrengthChecker</li>
        </ul>

        <h2 class="text-xl font-bold text-foreground mt-8">Accuracy of Materials</h2>
        <p>
          The materials appearing on StrengthChecker's website could include technical, typographical, or photographic errors. StrengthChecker does not warrant that any of the materials on its website are accurate, complete or current. StrengthChecker may make changes to the materials contained on its website at any time without notice. However, StrengthChecker does not make any commitment to update the materials.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Links</h2>
        <p>
          StrengthChecker has not reviewed all of the sites linked to its website and is not responsible for the contents of any such linked site. The inclusion of any link does not imply endorsement by StrengthChecker of the site. Use of any such linked website is at the user's own risk.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Limitation of Liability</h2>
        <p>
          In no event shall StrengthChecker, nor its officers, directors, and employees, be liable for anything arising out of or in any way connected with your use of this Website, whether such liability is under contract, tort, or otherwise. StrengthChecker, including its officers, directors, and employees, shall not be liable for any indirect, consequential, or special liability arising out of or in any way related to your use of this Website.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Indemnification</h2>
        <p>
          You hereby indemnify to the fullest extent StrengthChecker from and against any and/or all liabilities, costs, demands, causes of action, damages, and expenses arising in any way related to your breach of any of the provisions of these Terms.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Severability</h2>
        <p>
          If any provision of these Terms is found to be invalid under any applicable law, such provisions shall be deleted without affecting the remaining provisions herein.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Variation of Terms</h2>
        <p>
          StrengthChecker is permitted to revise these Terms at any time as it sees fit, and by using this Website you are expected to review these Terms on a regular basis.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Governing Law</h2>
        <p>
          These Terms will be governed by and interpreted in accordance with the laws of the jurisdiction in which we operate, and you submit to the non-exclusive jurisdiction of the state and federal courts located in our region for the resolution of any disputes.
        </p>
      </div>
    </Container>
  </Section>
</PageLayout>
