---
// src/pages/calculators/relative-strength.astro
import CalculatorLayout from '@/layouts/CalculatorLayout.astro';
import { RelativeStrength } from '@/components/calculators/RelativeStrength';
import { relativeStrengthFAQs } from '@/data/faqs';
import SEOFAQSection from '@/components/seo/SEOFAQSection.astro';
---

<CalculatorLayout
  title="Relative Strength Index Calculator | Lift to Bodyweight Ratio | StrengthChecker"
  description="Calculate your relative strength index and lift-to-bodyweight ratios. See how your relative strength ranks compared to the powerlifting and lifting community."
  calculatorName="Relative Strength Index Calculator"
  canonicalPath="/calculators/relative-strength"
>
  {/* The Relative Strength Island */}
  <RelativeStrength slot="calculator" client:load />

  {/* Sidebar Content */}
  <div slot="sidebar" class="p-6 border border-border bg-card rounded-xl shadow-sm space-y-6">
    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Relative Strength Index</h3>
    <p class="text-xs text-muted-foreground leading-relaxed">
      A <strong class="text-foreground">relative strength index</strong> measures your force output per unit of bodyweight. It is the definitive metric for weight-class athletes, powerlifting competitors, and calisthenics trainees.
    </p>
    <p class="text-xs text-muted-foreground leading-relaxed">
      A 100kg lifter benching 100kg is solid, but a 60kg lifter benching 100kg has an exceptional relative strength index. Ratios normalize raw weights to show true athletic capacity.
    </p>
    <div class="border-t border-border pt-4">
      <a href="/methodology" class="text-xs font-semibold text-primary hover:underline">
        Read calculations methodology →
      </a>
    </div>
  </div>

  {/* Bottom Editorial Content */}
  <div class="space-y-8 max-w-3xl">
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-foreground">Why Your Relative Strength Index Matters</h2>
      <p class="text-muted-foreground text-sm leading-relaxed">
        While absolute strength is useful for moving heavy machinery, your <strong class="text-foreground">relative strength index</strong> is the primary driver of athletic performance. It determines how fast you can sprint, how high you can jump, and how easily you can manipulate your own body structure.
      </p>
      <p class="text-muted-foreground text-sm leading-relaxed">
        This **Relative Strength Index Calculator** analyzes your force-to-mass ratio. It uses log-normal distribution probability curves to rank your ratio against standard competitive powerlifting tiers (Beginner to Elite) so you can compare progress objectively, regardless of your bodyweight.
      </p>
    </section>

    <section class="space-y-4">
      <h3 class="text-xl font-bold text-foreground">Evaluating Relative Strength in Bodyweight Exercises</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">
        For bodyweight movements like pull-ups and dips, the total force required is equal to your bodyweight plus the added weight on your belt. This calculator automatically incorporates your body weight to yield an accurate relative strength index, comparing your total load directly to standardized fitness metrics.
      </p>
    </section>

    <div class="border-t border-border/80 pt-6">
      <SEOFAQSection items={relativeStrengthFAQs} title="Relative Strength Index FAQs" />
    </div>
  </div>
</CalculatorLayout>
