---
// src/pages/about.astro
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';

const breadcrumbs = [{ name: 'About', path: '/about' }];
---

<PageLayout
  title="About StrengthChecker | The Strength Intelligence Platform"
  description="Learn about the mission, data science, and team behind StrengthChecker — the premium, definitive strength standards platform."
  canonicalPath="/about"
>
  <Section class="pt-6 md:pt-10">
    <Container>
      <Breadcrumbs items={breadcrumbs} />

      <div class="mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl">
          About <span class="text-gradient">StrengthChecker</span>
        </h1>
        <p class="mt-3 text-lg text-muted-foreground max-w-2xl">
          We build scientific strength intelligence tools for lifters, coaches, and researchers.
        </p>
      </div>

      <div class="prose prose-invert max-w-3xl leading-relaxed text-muted-foreground text-sm space-y-6">
        <h2 class="text-xl font-bold text-foreground">Our Mission</h2>
        <p>
          In the fitness industry, generic guidelines and anecdotal evidence abound. Trainees are often left with questions: "Is my squat actually strong?", "What should a person of my weight be bench pressing?", "Is my body development balanced?"
        </p>
        <p>
          StrengthChecker was created to provide clear, quantitative, and scientifically-grounded answers. We believe that strength metrics should be derived from empirical data and transparent calculations, not subjective claims.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">About the Project</h2>
        <p>
          This platform was created to help lifters benchmark their strength using publicly available strength standard datasets and published sports science research. 
        </p>
        <p>
          Instead of relying on unverified user-submitted entries (which are subject to reporting bias and weight inflation), we consolidate raw athletic results and perform regression analysis using log-normal probability distributions. This ensures the thresholds reflect realistic milestones for everyday lifters while remaining statistically anchored to empirical athletic results.
        </p>

        <h2 class="text-xl font-bold text-foreground mt-8">Methodology & Reference Data</h2>
        <p>
          Our calculations are modeled using:
        </p>
        <ul class="list-disc list-inside space-y-2 pl-2">
          <li><strong>Raw Powerlifting Datasets</strong>: Open-raw divisions from the International Powerlifting Federation (IPF) and related databases to identify elite, advanced, and intermediate limits.</li>
          <li><strong>Recreational Survey Studies</strong>: Surveyed statistics from fitness populations to establish standard novice and beginner thresholds.</li>
          <li><strong>IPF GL & Wilks Coefficients</strong>: Standard formulas used to normalize lifts relative to bodyweight, accounting for the Square-Cube Law of scaling.</li>
        </ul>

        <h2 class="text-xl font-bold text-foreground mt-8">Limitations & Disclaimers</h2>
        <p>
          All strength standards represent strict, full-range-of-motion repetitions (e.g., squatting to parallel, chest touch on bench, full lockout on deadlifts). 
        </p>
        <p>
          Please note that StrengthChecker is an independent data analysis tool. It provides statistical benchmarks based on competitive databases and recreationally modeled populations. These tools are designed to evaluate and guide training progression, and should not be used as medical advice or as a substitute for professional coaching.
        </p>
      </div>
    </Container>
  </Section>
</PageLayout>
