---
// src/pages/strength-standards.astro
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/layout/Container.astro';
import Section from '@/components/layout/Section.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import { exercises } from '@/data/exercises';
import { strengthCalculatorFAQs } from '@/data/faqs';
import SEOFAQSection from '@/components/seo/SEOFAQSection.astro';

const breadcrumbs = [{ name: 'Strength Standards', path: '/strength-standards' }];

const barbellLifts = exercises.filter(e => e.category === 'barbell');
const bodyweightLifts = exercises.filter(e => e.category === 'bodyweight' || e.category === 'weighted-bodyweight');
---

<PageLayout
  title="Strict Strength Standards & Gym Levels | StrengthChecker"
  description="Discover scientific strength standards for compound barbell and bodyweight movements. Find where you rank from Beginner to Elite."
  canonicalPath="/strength-standards"
>
  <Section class="pt-6 md:pt-10">
    <Container>
      <Breadcrumbs items={breadcrumbs} />

      <div class="mb-12">
        <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl">
          Strength <span class="text-gradient">Standards</span>
        </h1>
        <p class="mt-3 text-lg text-muted-foreground max-w-2xl">
          Accurate strength levels derived from raw powerlifting meets and survey data, categorized by pattern and muscle group.
        </p>
      </div>

      {/* Interactive Body Part Filters */}
      <div class="flex flex-wrap gap-2 mb-10 pb-4 border-b border-border/60" id="filter-buttons">
        <button data-filter="all" class="px-4 py-2 text-xs font-bold rounded-xl border border-primary/20 bg-primary/10 text-primary transition-all duration-200">All Exercises</button>
        <button data-filter="chest" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Chest</button>
        <button data-filter="back" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Back</button>
        <button data-filter="legs" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Legs</button>
        <button data-filter="shoulders" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Shoulders</button>
        <button data-filter="arms" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Arms</button>
        <button data-filter="core" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Core</button>
        <button data-filter="bodyweight" class="px-4 py-2 text-xs font-bold rounded-xl border border-border bg-card hover:border-primary/20 hover:text-primary transition-all duration-200">Bodyweight</button>
      </div>

      {/* Barbell Lifts Section */}
      <div class="space-y-6" id="barbell-section">
        <h2 class="text-2xl font-bold text-foreground border-b border-border pb-2" id="barbell-header">
          Barbell & Machine Exercises
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {barbellLifts.map((ex) => (
            <div class="exercise-card transition-all duration-300" data-muscle={ex.muscleGroup.toLowerCase()} data-category={ex.category}>
              <a
                href={`/strength-standards/${ex.slug}`}
                class="group p-6 border border-border rounded-xl bg-card hover:border-primary/40 hover:shadow-md transition-all duration-300 flex flex-col justify-between h-full"
              >
                <div>
                  <span class="text-[10px] font-mono font-bold tracking-widest text-primary uppercase">
                    {ex.muscleGroup}
                  </span>
                  <h3 class="text-lg font-bold text-foreground mt-2 group-hover:text-primary transition-colors">
                    {ex.name}
                  </h3>
                  <p class="text-xs text-muted-foreground mt-2 line-clamp-2">
                    {ex.description}
                  </p>
                </div>
                <span class="mt-6 flex items-center text-xs font-semibold text-primary">
                  <span>View standards</span>
                  <svg class="ml-1 h-3 w-3 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            </div>
          ))}
        </div>
      </div>

      {/* Bodyweight Lifts Section */}
      <div class="space-y-6 mt-16" id="bodyweight-section">
        <h2 class="text-2xl font-bold text-foreground border-b border-border pb-2" id="bodyweight-header">
          Bodyweight & Weighted Exercises
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {bodyweightLifts.map((ex) => (
            <div class="exercise-card transition-all duration-300" data-muscle={ex.muscleGroup.toLowerCase()} data-category={ex.category}>
              <a
                href={`/strength-standards/${ex.slug}`}
                class="group p-6 border border-border rounded-xl bg-card hover:border-primary/40 hover:shadow-md transition-all duration-300 flex flex-col justify-between h-full"
              >
                <div>
                  <span class="text-[10px] font-mono font-bold tracking-widest text-primary uppercase">
                    {ex.muscleGroup}
                  </span>
                  <h3 class="text-lg font-bold text-foreground mt-2 group-hover:text-primary transition-colors">
                    {ex.name}
                  </h3>
                  <p class="text-xs text-muted-foreground mt-2 line-clamp-2">
                    {ex.description}
                  </p>
                </div>
                <span class="mt-6 flex items-center text-xs font-semibold text-primary">
                  <span>View standards</span>
                  <svg class="ml-1 h-3 w-3 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </a>
            </div>
          ))}
        </div>
      </div>

      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          const buttons = document.querySelectorAll('#filter-buttons button');
          const cards = document.querySelectorAll('.exercise-card');
          const barbellHeader = document.querySelector('#barbell-header');
          const bodyweightHeader = document.querySelector('#bodyweight-header');

          buttons.forEach(btn => {
            btn.addEventListener('click', () => {
              // Reset other buttons
              buttons.forEach(b => {
                b.classList.remove('bg-primary/10', 'border-primary/20', 'text-primary');
                b.classList.add('bg-card', 'border-border');
              });
              
              // Set active button styles
              btn.classList.remove('bg-card', 'border-border');
              btn.classList.add('bg-primary/10', 'border-primary/20', 'text-primary');

              const filter = btn.getAttribute('data-filter');
              let visibleBarbell = 0;
              let visibleBodyweight = 0;

              cards.forEach(card => {
                const muscle = card.getAttribute('data-muscle');
                const category = card.getAttribute('data-category');
                const isBw = category === 'bodyweight' || category === 'weighted-bodyweight';

                let show = false;
                if (filter === 'all') {
                  show = true;
                } else if (filter === 'bodyweight') {
                  show = isBw;
                } else {
                  show = muscle === filter;
                }

                if (show) {
                  card.style.display = 'block';
                  if (isBw) visibleBodyweight++;
                  else visibleBarbell++;
                } else {
                  card.style.display = 'none';
                }
              });

              // Toggle section headers if they have zero matches
              if (barbellHeader) {
                barbellHeader.style.display = visibleBarbell > 0 ? 'block' : 'none';
              }
              if (bodyweightHeader) {
                bodyweightHeader.style.display = visibleBodyweight > 0 ? 'block' : 'none';
              }
            });
          });
        });
      </script>

      <SEOFAQSection items={strengthCalculatorFAQs} title="Strength Standards FAQs" class="mt-16" />
    </Container>
  </Section>
</PageLayout>
