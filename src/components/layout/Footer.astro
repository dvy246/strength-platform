---
// src/components/layout/Footer.astro
import Container from './Container.astro';
---

<footer class="border-t border-border bg-background py-12 mt-auto">
  <Container>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-4 lg:gap-12">
      {/* Brand Column */}
      <div class="flex flex-col space-y-4">
        <div class="flex items-center space-x-2">
          <img src="/favicon.svg" alt="StrengthAtlas Logo" class="h-5 w-5" />
          <span class="text-lg font-bold tracking-tight text-foreground">
            Strength<span class="text-primary">Atlas</span>
          </span>
        </div>
        <p class="text-sm text-muted-foreground max-w-xs">
          The definitive platform for strength standards, relative strength, and progress analysis. Derived from real data, not myths.
        </p>
      </div>

      {/* Lifts Column */}
      <div>
        <h3 class="text-sm font-semibold text-foreground uppercase tracking-wider mb-4">Strength Standards</h3>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li><a href="/strength-standards/bench-press" class="hover:text-foreground hover:underline">Bench Press</a></li>
          <li><a href="/strength-standards/squat" class="hover:text-foreground hover:underline">Squat</a></li>
          <li><a href="/strength-standards/deadlift" class="hover:text-foreground hover:underline">Deadlift</a></li>
          <li><a href="/strength-standards/overhead-press" class="hover:text-foreground hover:underline">Overhead Press</a></li>
          <li><a href="/strength-standards/pull-up" class="hover:text-foreground hover:underline">Pull-Up</a></li>
          <li><a href="/strength-standards/dips" class="hover:text-foreground hover:underline">Dips</a></li>
        </ul>
      </div>

      {/* Tools Column */}
      <div>
        <h3 class="text-sm font-semibold text-foreground uppercase tracking-wider mb-4">Calculators</h3>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li><a href="/calculators/strength-index" class="hover:text-foreground hover:underline">Strength Index</a></li>
          <li><a href="/calculators/one-rep-max-calculator" class="hover:text-foreground hover:underline">One Rep Max</a></li>
          <li><a href="/calculators/ideal-bodyweight" class="hover:text-foreground hover:underline">Ideal Bodyweight</a></li>
          <li><a href="/calculators/relative-strength" class="hover:text-foreground hover:underline">Relative Strength</a></li>
          <li><a href="/strength-standards" class="hover:text-foreground hover:underline">All Lifts</a></li>
        </ul>
      </div>

      {/* Platform Column */}
      <div>
        <h3 class="text-sm font-semibold text-foreground uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li><a href="/methodology" class="hover:text-foreground hover:underline">Calculations & Science</a></li>
          <li><a href="/about" class="hover:text-foreground hover:underline">About Us</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-muted-foreground">
      <span>
        &copy; {new Date().getFullYear()} StrengthAtlas. Built with data, not hype. All rights reserved.
      </span>
      <div class="flex space-x-6">
        <a href="/methodology" class="hover:text-foreground">Methodology</a>
        <a href="/about" class="hover:text-foreground">About</a>
      </div>
    </div>
  </Container>
</footer>
