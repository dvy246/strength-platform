---
// src/pages/calculators/pull-ups-one-rep-max-calculator.astro
import CalculatorLayout from '@/layouts/CalculatorLayout.astro';
import { OneRepMax } from '@/components/calculators/OneRepMax';
import StructuredData from '@/components/seo/StructuredData.astro';
import { buildBreadcrumbSchema, buildWebApplicationSchema } from '@/lib/seo/schema';
import { pullUpCalisthenicsFAQs } from '@/data/faqs';
import SEOFAQSection from '@/components/seo/SEOFAQSection.astro';

// Structured Data
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', item: '/' },
  { name: 'Calculators', item: '/calculators' },
  { name: 'Pull-Ups One Rep Max Calculator', item: '/calculators/pull-ups-one-rep-max-calculator' }
]);

const calculatorSchema = buildWebApplicationSchema(
  'Pull-Ups One Rep Max Calculator',
  'Estimate your pull-up and weighted pull-up one rep max (1RM) using scientific estimation formulas. Includes load metrics and percentage charts.',
  'https://strengthchecker.com/calculators/pull-ups-one-rep-max-calculator'
);

const schemas = [breadcrumbSchema, calculatorSchema];
---

<CalculatorLayout
  title="Pull-Ups One Rep Max Calculator | Calculate Pull-Up 1RM | StrengthChecker"
  description="Use the ultimate pull ups one rep max calculator to estimate your max added load. Accounts for bodyweight adjustments and outputs strict training zones."
  calculatorName="Pull-Ups One Rep Max Calculator"
  canonicalPath="/calculators/pull-ups-one-rep-max-calculator"
>
  <StructuredData slot="head" schema={schemas} />

  {/* The Interactive Calculator Island */}
  <OneRepMax slot="calculator" initialExerciseId="weighted-pull-up" client:load />

  {/* Sidebar Content */}
  <div slot="sidebar" class="p-6 border border-border bg-card rounded-xl shadow-sm space-y-6">
    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Pull-Up 1RM Metrics</h3>
    <p class="text-xs text-muted-foreground leading-relaxed">
      A strict <strong class="text-foreground">pull-up one rep max</strong> requires pulling your chin completely over the bar from a dead hang position.
    </p>
    <p class="text-xs text-muted-foreground leading-relaxed">
      For bodyweight movements, the true load lifted is your bodyweight plus the added weight on your belt. This calculator incorporates both to output correct benchmarks.
    </p>
    <div class="border-t border-border pt-4 text-xs font-semibold space-y-2">
      <a href="/calculators/bench-press-one-rep-max-calculator" class="block text-primary hover:underline">
        Bench Press 1RM Calculator →
      </a>
      <a href="/calculators/relative-strength" class="block text-primary hover:underline">
        Relative Strength Calculator →
      </a>
    </div>
  </div>

  {/* Bottom Editorial Content */}
  <div class="space-y-8 max-w-3xl">
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-foreground">Why Use a Pull-Ups 1 Rep Max Calculator?</h2>
      <p class="text-muted-foreground text-sm leading-relaxed">
        The pull-up is the ultimate assessment of relative upper-body pulling strength. Once you can perform more than 10-12 bodyweight pull-ups, adding external load (weighted pull-ups) becomes necessary to drive strength progress.
      </p>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Using a dedicated <strong class="text-foreground">pull ups 1 rep max calculator</strong> is essential because calisthenics exercises scale differently than barbell lifts. Instead of calculating based on the added weight alone, our tool calculates based on the combined load (bodyweight + added weight) to ensure the Epley and Brzycki equations remain statistically valid.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-xl font-bold text-foreground">How the Pull-Up 1RM Calculation Works</h2>
      <p class="text-muted-foreground text-sm leading-relaxed">
        To calculate your pull-up 1RM, we execute the following steps:
      </p>
      <ol class="list-decimal pl-5 text-muted-foreground text-sm space-y-2">
        <li>Determine your total system weight: <code>Total Weight = Bodyweight + Added Weight</code>.</li>
        <li>Apply the selected 1RM equation (e.g. Epley: <code>1RM Total = Total Weight × (1 + Reps/30)</code>).</li>
        <li>Subtract your bodyweight from the 1RM total to estimate your 1RM added weight: <code>Estimated Added Max = 1RM Total - Bodyweight</code>.</li>
      </ol>
      <p class="text-muted-foreground text-sm leading-relaxed">
        This mathematical adjustment ensures that your calculated relative capability represents your actual strength output, preventing the underestimation that occurs when ignoring bodyweight in standard formulas.
      </p>
    </section>

    <div class="border-t border-border/80 pt-6">
      <SEOFAQSection items={pullUpCalisthenicsFAQs} title="Pull-Up & 1RM FAQs" />
    </div>
  </div>
</CalculatorLayout>
